# ============================================================
# .env.example — 이 파일을 복사해서 .env.local 로 저장하세요
# .env.local 은 절대 git에 올리면 안 됩니다! (API 키 유출 위험)
# ============================================================

# PostgreSQL DB 주소 (Supabase 대시보드 → Settings → Database → Connection string)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/babpbang_db?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/babpbang_db"

# 카카오 지도 API 키 (https://developers.kakao.com)
# NEXT_PUBLIC_ 붙이면 브라우저에서도 사용 가능
NEXT_PUBLIC_KAKAO_MAP_KEY="여기에_카카오_JavaScript_앱_키_입력"

# 앱 기본 URL (배포 후 실제 도메인으로 변경)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
